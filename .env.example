# ============================================================
# E-Commerce Platform - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================================
# Application Settings
# ============================================================
NODE_ENV=development
PORT=3000
SERVICE_NAME=api-gateway

# ============================================================
# Database - PostgreSQL
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce_db
DB_USER=ecommerce_user
DB_PASSWORD=ecommerce_secure_password_2024
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_SSL_REJECT_UNAUTHORIZED=false
DB_SSL_CA=

# ============================================================
# Cache - Redis
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_password_2024
REDIS_URL=redis://:redis_secure_password_2024@localhost:6379

# ============================================================
# Authentication - JWT
# ============================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=ecommerce-platform
JWT_AUDIENCE=ecommerce-api

# ============================================================
# Stripe - Payment Processing
# ============================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================================
# OAuth2 - Google (optional)
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ============================================================
# OAuth2 - Facebook (optional)
# ============================================================
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback

# ============================================================
# Email Service (optional)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@ecommerce-platform.com
EMAIL_NAME=E-Commerce Platform

# ============================================================
# CORS Configuration
# ============================================================
CORS_ORIGIN=http://localhost:3000,http://localhost:5000

# ============================================================
# Rate Limiting
# ============================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================
# File Upload
# ============================================================
UPLOAD_MAX_FILE_SIZE=5242880
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp
UPLOAD_DEST=uploads/products

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=debug
LOG_FORMAT=json

# ============================================================
# Nginx
# ============================================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ============================================================
# API Gateway Ports for Microservices
# ============================================================
API_PORT=3000
AUTH_SERVICE_PORT=3001
PRODUCT_SERVICE_PORT=3002
ORDER_SERVICE_PORT=3003
ADMIN_SERVICE_PORT=3004
