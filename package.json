{
  "name": "ecommerce-platform",
  "version": "2.1.0",
  "description": "Plateforme e-commerce complète avec gestion des stocks, panier, paiement Stripe sécurisé et tableau de bord admin. Architecture microservices avec API Gateway, JWT auth et Redis cache.",
  "main": "src/server.js",
  "author": {
    "name": "Sekouna KABA",
    "email": "sekouna.kaba@email.com",
    "url": "https://github.com/sekounakaba"
  },
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/sekounakaba/ecommerce-platform.git"
  },
  "keywords": [
    "ecommerce",
    "e-commerce",
    "platform",
    "nodejs",
    "react",
    "postgresql",
    "redis",
    "stripe",
    "microservices",
    "api-gateway",
    "docker",
    "jwt",
    "authentication",
    "payment",
    "fullstack"
  ],
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config jest.e2e.config.js",
    "test:coverage": "jest --coverage --coverageDirectory=coverage",
    "lint": "eslint src/ --ext .js --fix",
    "lint:check": "eslint src/ --ext .js",
    "format": "prettier --write \"src/**/*.js\"",
    "db:create": "node scripts/create-db.js",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "db:rollback": "node scripts/rollback.js",
    "docker:up": "docker-compose up -d --build",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart",
    "docker:clean": "docker-compose down -v && docker system prune -f"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "joi": "^17.12.3",
    "json2csv": "^5.0.7",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.12.0",
    "redis": "^4.6.13",
    "sharp": "^0.33.3",
    "slugify": "^1.6.6",
    "stripe": "^15.8.0",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.2",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
